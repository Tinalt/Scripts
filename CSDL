CREATE TRIGGER trg_CheckTongSV
ON SINHVIEN
AFTER INSERT, DELETE, UPDATE
AS
BEGIN
    IF EXISTS (
        SELECT *
        FROM KHOA K
        WHERE K.TongSoSV <> (
            SELECT COUNT(*)
            FROM SINHVIEN S
            WHERE S.MaKhoa = K.MaKhoa
        )
    )
    BEGIN
        PRINT N'Sai TongSoSV!';
        ROLLBACK TRANSACTION;
    END
END;
GO

SELECT SV.HoTenSV, DT.TenDeTai, GV.HoTenGV
FROM SINHVIEN SV
JOIN KHOA K ON SV.MaKhoa = K.MaKhoa
JOIN HUONGDAN HD ON SV.MaSV = HD.MaSV
JOIN DETAI DT ON HD.MaDeTai = DT.MaDeTai
JOIN GIANGVIEN GV ON DT.MaGV = GV.MaGV
WHERE K.TenKhoa = N'Công nghệ thông tin'
ORDER BY DT.TenDeTai;

SELECT GV.HoTenGV, COUNT(DT.MaDeTai) AS SoLuongDeTai
FROM GIANGVIEN GV
LEFT JOIN DETAI DT ON GV.MaGV = DT.MaGV
GROUP BY GV.HoTenGV;

SELECT GV.HoTenGV, DT.Nam, COUNT(*) AS SoLuongDeTai
FROM GIANGVIEN GV
JOIN DETAI DT ON GV.MaGV = DT.MaGV
GROUP BY GV.HoTenGV, DT.Nam
ORDER BY GV.HoTenGV, DT.Nam;


